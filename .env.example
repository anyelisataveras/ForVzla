# ── PostHog (public/analytics-config.js — clave pública, va en el HTML) ──
# Dashboard → Project Settings → Project API Key (phc_...)
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Scraper (scraper/ingesta_redes.js) ──
# NO comitees el .env real. Solo esta plantilla.

# Apify — actores: instagram-search-scraper, tiktok-scraper, tweet-scraper
APIFY_TOKEN=

# Anthropic (clasificación de posts con Claude Haiku)
ANTHROPIC_API_KEY=

# Supabase — SERVICE_ROLE key (secret). NO uses la anon/publishable aquí.
# Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://ebsgvamzaegjgpjkpick.supabase.co
SUPABASE_KEY=

# Publishable/anon key (admin server verifica JWT; misma que en index.html/admin.html)
SUPABASE_ANON_KEY=

# Puerto del servidor scraper (admin.html → POST /run). Railway usa PORT automáticamente.
SCRAPER_PORT=3456

# URL pública del scraper (solo para documentar; el admin la lee de public/scraper-config.js)
# SCRAPER_PUBLIC_URL=https://tu-servicio.up.railway.app

# Pon 1 para correr sin escribir en la BD (recomendado la 1ª vez)
DRY_RUN=0

# Plataformas a scrapear (coma-separadas)
PLATFORMS=instagram,tiktok,twitter,telegram

# Búsqueda: omitir KEYWORDS/HASHTAGS para usar defaults de scraper/lib/config.js (términos PM)
# Override manual: KEYWORDS=term1,term2  HASHTAGS=Tag1,Tag2

# Límites por plataforma (controla costo Apify)
MAX_RESULTS_INSTAGRAM=120
MAX_RESULTS_TIKTOK=120
MAX_RESULTS_TWITTER=120
MAX_RESULTS_TELEGRAM=100

# Telegram Bot API (el bot debe ser miembro/admin del canal)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNELS=AlertasVenezuela,VenezuelaAyuda
