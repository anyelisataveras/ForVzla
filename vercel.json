{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/rescatistas", "destination": "/rescatistas.html" },
    { "source": "/cuidadoras-caracas", "destination": "/cuidadoras-caracas.html" },
    { "source": "/voluntarios/cuidadoras-caracas", "destination": "/cuidadoras-caracas.html" },
    { "source": "/rescate", "destination": "/rescatistas.html" },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
